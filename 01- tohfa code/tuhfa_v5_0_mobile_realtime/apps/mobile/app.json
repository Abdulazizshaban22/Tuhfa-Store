
{
  "expo": {
    "name": "Tuhfa",
    "slug": "tuhfa",
    "version": "5.0.0",
    "scheme": "tuhfa",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "url": "https://u.expo.dev/00000000-0000-0000-0000-000000000000",
      "enabled": true
    },
    "ios": {
      "bundleIdentifier": "sa.tuhfa.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSUserTrackingUsageDescription": "نستخدم المعرّف لتحسين التجربة.",
        "NFCReaderUsageDescription": "نستخدم NFC لربط القطع بشهادات الأصالة.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "entitlements": {
        "aps-environment": "development"
      }
    },
    "android": {
      "package": "sa.tuhfa.app",
      "permissions": ["android.permission.NFC", "com.google.android.c2dm.permission.RECEIVE"],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-notifications"
    ]
  }
}
