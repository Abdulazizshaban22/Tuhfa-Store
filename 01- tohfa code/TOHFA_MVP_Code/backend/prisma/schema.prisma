generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [
    { name = "pgvector", version = "0.7.4" }
  ]
}

enum ProductStatus {
  READY
  MADE_TO_ORDER
  MUSEUM_GRADE
}

enum HostType {
  ARTISAN
  MUSEUM
}

model Region {
  code       String  @id
  nameAr     String
  capitalAr  String
  artisans   Artisan[]
  craftTypes CraftType[] @relation("RegionCraftType")
}

model CraftType {
  code              String   @id
  nameAr            String
  regionPrimaryCode String?
  regionPrimary     Region?  @relation(fields: [regionPrimaryCode], references: [code])
  descriptionAr     String?
  patterns          String[]
  materials         String[]
  products          Product[]
}

model Artisan {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique
  nameAr      String
  regionCode  String?
  region      Region?  @relation(fields: [regionCode], references: [code])
  specialties String[]
  storeHandle String   @unique
  instagram   String?
  bioAr       String?
  products    Product[]
  workshops   Workshop[]
}

model Exhibit {
  id              Int       @id @default(autoincrement())
  externalId      String    @unique
  museumNameAr    String
  cityAr          String
  titleAr         String
  iiifManifestUrl String
  descriptionAr   String?
  products        Product[]
  workshops       Workshop[]
}

model Product {
  id                    Int            @id @default(autoincrement())
  externalId            String         @unique
  titleAr               String
  status                ProductStatus
  priceSar              Int
  stockQty              Int            @default(0)
  madeToOrderLeadDays   Int?
  images                String[]
  craftTypeCode         String
  craftType             CraftType      @relation(fields: [craftTypeCode], references: [code])
  artisanId             Int?
  artisan               Artisan?       @relation(fields: [artisanId], references: [id])
  museumExhibitId       Int?
  museumExhibit         Exhibit?       @relation(fields: [museumExhibitId], references: [id])
  passport              Passport?
  // Optional: image/text embedding for AI similarity (pgvector)
  // embedding           Unsupported("vector(768)")?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model Workshop {
  id            Int       @id @default(autoincrement())
  externalId    String    @unique
  hostType      HostType
  craftTypeCode String
  craftType     CraftType @relation(fields: [craftTypeCode], references: [code])
  titleAr       String
  dateStart     DateTime
  durationHours Int       @default(2)
  priceSar      Int       @default(0)
  capacity      Int       @default(10)
  venueAr       String?
  online        Boolean   @default(false)
  artisanId     Int?
  artisan       Artisan?  @relation(fields: [artisanId], references: [id])
  exhibitId     Int?
  exhibit       Exhibit?  @relation(fields: [exhibitId], references: [id])
}

model Passport {
  id         Int     @id @default(autoincrement())
  externalId String  @unique
  productId  Int     @unique
  product    Product @relation(fields: [productId], references: [id])
  qrText     String
  nfcTagUid  String
  c2paRef    String?
}
