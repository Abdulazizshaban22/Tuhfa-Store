# API (NestJS) — Local Dev
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@db:5432/tohfa?schema=public
CORS_ORIGINS=*
DEMO_MODE=1

# Optional payments (choose one provider and fill sandbox keys)
TAP_SECRET_KEY=sk_test_xxx
TAP_MERCHANT_ID=merchant_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Optional Web3 / NFT
POLYGON_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_KEY
CHAIN_ID=80001
WEB3_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NFT_MINT_FN=mint
